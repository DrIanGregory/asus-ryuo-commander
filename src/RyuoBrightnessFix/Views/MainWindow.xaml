<Window x:Class="RyuoBrightnessFix.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ryuo Brightness Fix"
        Icon="/Resources/Icons/app.ico"
        Width="960" Height="800"
        MinWidth="900" MinHeight="620"
        WindowStartupLocation="Manual"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="18,18,18,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header with status badge ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Ryuo Brightness Fix" FontSize="20" FontFamily="Segoe UI Semibold" />
                <TextBlock Text="{Binding DeviceStatus}" Style="{StaticResource SubtleText}" Margin="0,4,0,0" />
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource StatusBadge}" Background="#FF202024"
                    BorderBrush="{Binding StatusBrush}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center" Fill="{Binding StatusBrush}" />
                    <TextBlock Text="{Binding StatusText}" Margin="7,0,0,0" VerticalAlignment="Center"
                               FontFamily="Segoe UI Semibold" Foreground="{Binding StatusBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Tabs ===== -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

            <!-- ================= BRIGHTNESS ================= -->
            <TabItem Header="Brightness">
                <StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="LCD Brightness" Style="{StaticResource HeaderText}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Minimum="0" Maximum="100"
                                        Value="{Binding BrightnessPercent, Mode=TwoWay}"
                                        IsEnabled="{Binding SliderEnabled}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Width="52" TextAlignment="Right" VerticalAlignment="Center"
                                           FontSize="18" FontFamily="Segoe UI Semibold"
                                           Text="{Binding BrightnessPercent, StringFormat={}{0}%}" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Apply" Style="{StaticResource AccentButton}"
                                        Command="{Binding ApplyBrightnessCommand}" Width="110" />
                                <Button Content="100%" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding Restore100Command}" Width="90" Margin="10,0,0,0" />
                            </StackPanel>
                            <CheckBox Content="Hold brightness (stops the panel dimming itself after a few seconds)"
                                      IsChecked="{Binding KeepBrightnessAlive}" Margin="0,14,0,0" />
                            <CheckBox Content="Restore this brightness after waking"
                                      IsChecked="{Binding AutoFixOnResume}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <TextBlock Style="{StaticResource SubtleText}" TextWrapping="Wrap"
                                   Text="Sets the Ryuo IV LCD brightness directly over the vendor USB HID channel — no adb, and no ASUS Info Hub needed. 'Hold brightness' keeps a live USB connection to the panel (reading its stream) so its firmware doesn't fall back to the dim standby it uses when the PC stops talking to it. Because it uses the same USB channel as ASUS Info Hub, run one or the other — not both at once. (During real sleep the PC is off so the panel dims; it's restored on wake.)" />
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ================= VIDEO (Info Hub-style editor: screen + live widgets,
                 media library with the three play modes, metrics chips alongside) ================= -->
            <TabItem Header="Video">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <!-- ===== Left: LCD screen + media library ===== -->
                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="{Binding PreviewTitle}" Style="{StaticResource SubtleText}"
                                               Margin="0,0,0,6"
                                               Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}" />
                                    <Viewbox Stretch="Uniform" HorizontalAlignment="Left"
                                             Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}">
                                        <Border Width="415" Height="200" Background="Black"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                                                CornerRadius="6">
                                            <Border.Clip>
                                                <RectangleGeometry Rect="0,0,411,196" RadiusX="5" RadiusY="5" />
                                            </Border.Clip>
                                            <Grid>
                                                <!-- Manual behavior is REQUIRED: the loop handler calls
                                                     Play(), which WPF forbids for any other mode. -->
                                                <MediaElement x:Name="PreviewPlayer"
                                                              Source="{Binding PreviewSource}"
                                                              LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                                              IsMuted="True" Stretch="UniformToFill"
                                                              MediaOpened="PreviewPlayer_MediaOpened"
                                                              MediaEnded="PreviewPlayer_MediaEnded"
                                                              MediaFailed="PreviewPlayer_MediaFailed" />
                                                <!-- Live widgets, at the panel's real placements -->
                                                <ItemsControl ItemsSource="{Binding MetricOverlays}"
                                                              Visibility="{Binding MetricsEnabled, Converter={StaticResource BoolToVis}}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#5A3A3A3A" CornerRadius="2" Padding="5,3"
                                                                    MinWidth="72">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Title}" FontSize="6"
                                                                               Foreground="#CCBBBBBB" />
                                                                    <TextBlock Text="{Binding Value}" FontSize="12"
                                                                               FontFamily="Segoe UI Semibold"
                                                                               Foreground="{Binding DataContext.MetricContentBrush,
                                                                                            RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Border>
                                    </Viewbox>
                                    <TextBlock x:Name="PreviewError" Style="{StaticResource SubtleText}"
                                               TextWrapping="Wrap" Margin="0,4,0,0" Visibility="Collapsed" />
                                </StackPanel>
                            </Border>

                            <!-- Media library: header with the three play modes, thumbnail strip
                                 with its scrollbar underneath, controls below -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Media library"
                                                   Style="{StaticResource HeaderText}" Margin="0" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <ToggleButton Style="{StaticResource ModeToggle}" Content="&#x1F502; Repeat one"
                                                          IsChecked="{Binding IsRepeatOne}"
                                                          ToolTip="Loop the selected video forever" />
                                            <ToggleButton Style="{StaticResource ModeToggle}" Content="&#x1F501; Repeat all"
                                                          IsChecked="{Binding IsRepeatAll}" Margin="6,0,0,0"
                                                          ToolTip="Play every video in order, then start over" />
                                            <ToggleButton Style="{StaticResource ModeToggle}" Content="&#x1F500; Shuffle"
                                                          IsChecked="{Binding IsShuffle}" Margin="6,0,0,0"
                                                          ToolTip="Rotate through the videos in random order" />
                                        </StackPanel>
                                    </Grid>

                                    <ListBox Background="Transparent" BorderThickness="0"
                                             ItemsSource="{Binding Playlist}"
                                             SelectedItem="{Binding SelectedPlaylistItem, Mode=TwoWay}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Visible"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd" BorderThickness="2" CornerRadius="4"
                                                                    Margin="3" Background="Black"
                                                                    BorderBrush="{StaticResource BorderBrush}">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="BorderBrush"
                                                                            Value="{StaticResource AccentBrush}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="120" Height="60" ToolTip="{Binding File}">
                                                    <TextBlock Text="{Binding File}" FontSize="9"
                                                               Foreground="{StaticResource SubtleForegroundBrush}"
                                                               TextWrapping="Wrap" Margin="4" />
                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Button Content="Add" Style="{StaticResource AccentButton}"
                                                    Command="{Binding ChooseVideoCommand}" Padding="18,5" />
                                            <Button Content="Remove" Style="{StaticResource SecondaryButton}"
                                                    Command="{Binding RemoveVideoCommand}" Padding="12,5" Margin="8,0,0,0" />
                                            <Button Content="Move left" Style="{StaticResource SecondaryButton}"
                                                    Command="{Binding MoveVideoUpCommand}" Padding="12,5" Margin="8,0,0,0"
                                                    ToolTip="Play the selected video earlier in the queue" />
                                            <Button Content="Move right" Style="{StaticResource SecondaryButton}"
                                                    Command="{Binding MoveVideoDownCommand}" Padding="12,5" Margin="8,0,0,0"
                                                    ToolTip="Play the selected video later in the queue" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <TextBlock Text="Scale mode:" VerticalAlignment="Center"
                                                       Style="{StaticResource SubtleText}" />
                                            <ComboBox ItemsSource="{Binding VideoScaleModes}"
                                                      SelectedItem="{Binding SelectedVideoScaleMode, Mode=TwoWay}"
                                                      Width="100" Margin="8,0,0,0" VerticalAlignment="Center"
                                                      ToolTip="Fill = crop to cover the screen; Fit = letterbox; Stretch = distort.&#x0a;Applies to the whole library — changing it re-encodes the videos from their original files." />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="{Binding VideoStatus}" Style="{StaticResource SubtleText}"
                                               Margin="0,8,0,0" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ActiveVideoDisplay}" Style="{StaticResource SubtleText}"
                                               Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===== Right: on-screen metrics, next to the video ===== -->
                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="12,0,0,12"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="On-screen metrics" Style="{StaticResource HeaderText}" />
                                <CheckBox Content="Show metrics on the LCD"
                                          IsChecked="{Binding MetricsEnabled}" />
                                <TextBlock Text="{Binding MetricsAccessNote}" Style="{StaticResource SubtleText}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"
                                           Visibility="{Binding ShowMetricsAccessNote, Converter={StaticResource BoolToVis}}" />
                                <ItemsControl ItemsSource="{Binding MetricGroups}" Margin="0,6,0,0"
                                              IsEnabled="{Binding MetricsEnabled}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,6,0,0">
                                                <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold"
                                                           FontSize="12" Foreground="{StaticResource ForegroundBrush}" />
                                                <ItemsControl ItemsSource="{Binding Chips}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ToggleButton Style="{StaticResource ChipToggle}"
                                                                          Content="{Binding Label}"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding MetricsStatus}" Style="{StaticResource SubtleText}"
                                           Margin="0,6,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                            IsEnabled="{Binding MetricsEnabled}">
                                    <TextBlock Text="Title color" VerticalAlignment="Center"
                                               Style="{StaticResource SubtleText}" />
                                    <Border Width="16" Height="16" Margin="6,0,0,0" CornerRadius="3"
                                            Background="{Binding MetricTitleBrush}" />
                                    <TextBox Style="{StaticResource InputBox}" Width="84" Margin="6,0,0,0"
                                             Text="{Binding MetricTitleColor, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                            IsEnabled="{Binding MetricsEnabled}">
                                    <TextBlock Text="Content color" VerticalAlignment="Center"
                                               Style="{StaticResource SubtleText}" />
                                    <Border Width="16" Height="16" Margin="6,0,0,0" CornerRadius="3"
                                            Background="{Binding MetricContentBrush}" />
                                    <TextBox Style="{StaticResource InputBox}" Width="84" Margin="6,0,0,0"
                                             Text="{Binding MetricContentColor, UpdateSourceTrigger=LostFocus}" />
                                </StackPanel>

                                <!-- Fan labels: this board reports fans generically ("Fan #7"),
                                     so let the user name each detected header. The typed name is
                                     what the panel widget "Fan Speed <name>" then matches. -->
                                <StackPanel Margin="0,14,0,0"
                                            Visibility="{Binding HasFanMappings, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Fan labels" FontFamily="Segoe UI Semibold" FontSize="12"
                                               Foreground="{StaticResource ForegroundBrush}" />
                                    <TextBlock Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Text="Pick a name for each detected fan (or type your own). The panel widget 'Fan Speed …' matches it. Identify each by its live RPM — the pump stays steady, radiator fans ramp with load. Defaults are the app's best guess." />
                                    <ItemsControl ItemsSource="{Binding FanMappings}" Margin="0,6,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="{Binding Display}" VerticalAlignment="Center"
                                                               Width="150" Style="{StaticResource SubtleText}" />
                                                    <!-- Plain SelectedItem binding (each fan has its own RoleOptions
                                                         list that includes its current label) reliably displays the
                                                         value, unlike an editable ComboBox's Text binding. -->
                                                    <ComboBox Width="150" Margin="6,0,0,0"
                                                              ItemsSource="{Binding RoleOptions}"
                                                              SelectedItem="{Binding Label, Mode=TwoWay}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ================= SETTINGS ================= -->
            <TabItem Header="Settings">
                <StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Startup &amp; System Tray" Style="{StaticResource HeaderText}" />
                            <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" />
                            <TextBlock Text="{Binding StartupModeNote}" Style="{StaticResource SubtleText}"
                                       TextWrapping="Wrap" Margin="24,0,0,4"
                                       Visibility="{Binding ShowStartupModeNote, Converter={StaticResource BoolToVis}}" />
                            <CheckBox Content="Start minimized" IsChecked="{Binding StartMinimized}" />
                            <CheckBox Content="Minimize to tray when closing" IsChecked="{Binding MinimizeToTrayOnClose}" />
                            <CheckBox Content="Show tray icon" IsChecked="{Binding ShowTrayIcon}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Diagnostics" Style="{StaticResource HeaderText}" />
                            <CheckBox Content="Verbose debug logging (adb commands, power events, timing)"
                                      IsChecked="{Binding DebugLogging}" />
                            <TextBlock Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,6,0,0"
                                       Text="Turn this on, reproduce the problem (e.g. sleep/wake or click Apply), then open the logs folder and share the latest ryuo-*.log file." />
                            <Button Content="Open logs folder" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding OpenLogsFolderCommand}" HorizontalAlignment="Left"
                                    Padding="12,6" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Activity" Style="{StaticResource HeaderText}" />
                            <TextBox Style="{StaticResource LogBox}" Height="140" Text="{Binding LogText, Mode=OneWay}"
                                     x:Name="LogTextBox" TextChanged="LogTextBox_TextChanged" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource SubtleText}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding ConfigPathDisplay}"
                                   Text="{Binding ConfigPathDisplay}" />
                        <Button Grid.Column="1" Content="Re-check LCD" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ReloadCommand}" Padding="12,6" Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Margin="-18,10,-18,0" Padding="18,6,18,7"
                Background="#FF202024" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource StatusBarLinkButton}"
                        Command="{Binding CopyVersionCommand}"
                        ToolTip="Click to copy the version to the clipboard">
                    <TextBlock>
                        <Run Text="Version" /><Run Text=" " /><Run Text="{Binding AppVersion, Mode=OneWay}" />
                    </TextBlock>
                </Button>
                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                           FontFamily="Segoe UI Semibold" Foreground="{StaticResource AccentBrush}"
                           Text="{Binding VersionFeedbackText}"
                           Visibility="{Binding VersionFeedbackVisible, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
